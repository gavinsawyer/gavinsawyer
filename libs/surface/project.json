{
  "name":        "surface",
  "$schema":     "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot":  "libs/surface/src",
  "targets":     {
    "build": {
      "dependsOn": [ "lint" ],
      "executor":  "@nx/esbuild:esbuild",
      "options":   {
        "declaration":    true,
        "esbuildOptions": {
          "banner": {
            "css": "/*!\n / Copyright © 2026 Gavin William Sawyer. All rights reserved.\n /\n",
            "js":  "/*\n * Copyright © 2026 Gavin William Sawyer. All rights reserved.\n */\n"
          }
        },
        "external":       [ "@bowstring/*" ],
        "main":           "libs/surface/src/index.ts",
        "metafile":       true,
        "minify":         true,
        "outputPath":     "dist/libs/surface",
        "splitting":      true,
        "treeShaking":    true,
        "tsConfig":       "libs/surface/tsconfig.lib.json"
      },
      "outputs":   [ "{workspaceRoot}/dist/libs/surface" ]
    },
    "lint":  {
      "executor": "@nx/eslint:lint",
      "options":  { "lintFilePatterns": [ "libs/surface/src/**/*.ts" ] }
    }
  }
}
