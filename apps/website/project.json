{
  "name":        "website",
  "$schema":     "../../node_modules/nx/schemas/project-schema.json",
  "i18n":        {
    "locales":      {
      "en-GB": {
        "baseHref":    "/en-GB/",
        "translation": "libs/i18n/src/lib/messages/lib/en-GB.json"
      },
      "es-ES": {
        "baseHref":    "/es-ES/",
        "translation": "libs/i18n/src/lib/messages/lib/es-ES.json"
      },
      "fr-FR": {
        "baseHref":    "/fr-FR/",
        "translation": "libs/i18n/src/lib/messages/lib/fr-FR.json"
      }
    },
    "sourceLocale": "en-US"
  },
  "projectType": "application",
  "sourceRoot":  "apps/website/src",
  "targets":     {
    "angular--browser":        {
      "configurations":       {
        "development": {
          "localize":  [ "en-US" ],
          "sourceMap": true
        },
        "production":  {
          "budgets":          [
            {
              "maximumError":   "8mb",
              "maximumWarning": "2mb",
              "type":           "initial"
            },
            {
              "maximumError":   "64kb",
              "maximumWarning": "12kb",
              "type":           "anyComponentStyle"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/website/src/environment.ts",
              "with":    "apps/website/src/environment.prod.ts"
            }
          ],
          "localize":         true
        }
      },
      "defaultConfiguration": "production",
      "dependsOn":            [ "build--service-worker" ],
      "executor":             "@angular-devkit/build-angular:browser",
      "options":              {
        "allowedCommonJsDependencies": [
          "lodash",
          "masonry-layout",
          "url",
          "xhr2"
        ],
        "assets":                      [
          "apps/website/src/assets",
          "apps/website/src/robots.txt",
          "apps/website/src/sitemap.xml"
        ],
        "deleteOutputPath":            false,
        "index":                       "apps/website/src/index.original.html",
        "inlineStyleLanguage":         "sass",
        "main":                        "apps/website/src/app/main.browser.ts",
        "outputHashing":               "all",
        "outputPath":                  "dist/apps/website/browser",
        "polyfills":                   [ "zone.js" ],
        "styles":                      [ "apps/website/src/styles.sass" ],
        "tsConfig":                    "apps/website/tsconfig.app.json"
      },
      "outputs":              [ "{workspaceRoot}/dist/apps/website/browser" ]
    },
    "angular--extract-i18n":   {
      "dependsOn": [ "build--service-worker" ],
      "executor":  "@nx/angular:extract-i18n",
      "options":   {
        "buildTarget": "website:angular--browser:production",
        "format":      "json",
        "outFile":     "website.en-US.json",
        "outputPath":  "tmp/libs/i18n/extracts",
        "progress":    true
      },
      "outputs":   [ "{workspaceRoot}/tmp/libs/i18n/extracts" ]
    },
    "angular--server":         {
      "configurations":       {
        "development": {
          "outputHashing": "none",
          "sourceMap":     true
        },
        "production":  {
          "fileReplacements": [
            {
              "replace": "apps/website/src/environment.ts",
              "with":    "apps/website/src/environment.prod.ts"
            }
          ],
          "localize":         true,
          "outputHashing":    "media"
        }
      },
      "defaultConfiguration": "production",
      "dependsOn":            [ "build--intl-server" ],
      "executor":             "@angular-devkit/build-angular:server",
      "options":              {
        "deleteOutputPath":     false,
        "externalDependencies": [ "firebase-admin" ],
        "inlineStyleLanguage":  "sass",
        "main":                 "apps/website/src/app/main.server.ts",
        "outputPath":           "dist/apps/website/server",
        "tsConfig":             "apps/website/tsconfig.app.json"
      },
      "outputs":              [ "{workspaceRoot}/dist/apps/website/server" ]
    },
    "angular--ssr-dev-server": {
      "continuous": true,
      "dependsOn":  [ "build--service-worker" ],
      "executor":   "@angular-devkit/build-angular:ssr-dev-server",
      "options":    {
        "browserTarget": "website:angular--browser:development",
        "serverTarget":  "website:angular--server:development",
        "ssl":           true
      }
    },
    "build":                   {
      "dependsOn": [
        "angular--browser",
        "angular--server"
      ],
      "executor":  "nx:noop",
      "outputs":   [ "{workspaceRoot}/dist/apps/website" ]
    },
    "build--intl-server":      {
      "dependsOn": [ "esbuild--intl-server" ],
      "executor":  "nx:run-commands",
      "options":   { "commands": [ "mv dist/apps/website/server/main.intl-server.cjs dist/apps/website/server/main.js" ] },
      "outputs":   [ "{workspaceRoot}/dist/apps/website/server" ]
    },
    "build--service-worker":   {
      "dependsOn": [
        "lint",
        "prebuild"
      ],
      "executor":  "@nx/esbuild:esbuild",
      "options":   {
        "deleteOutputPath": false,
        "esbuildOptions":   {
          "banner": {
            "css": "/*!\n / Copyright © 2026 Gavin William Sawyer. All rights reserved.\n /\n",
            "js":  "/*\n * Copyright © 2026 Gavin William Sawyer. All rights reserved.\n */\n"
          }
        },
        "main":             "apps/website/src/app/main.service-worker.ts",
        "metafile":         true,
        "minify":           true,
        "outputPath":       "dist/apps/website/browser",
        "thirdParty":       true,
        "tsConfig":         "apps/website/tsconfig.app.json"
      },
      "outputs":   [ "{workspaceRoot}/dist/apps/website/browser" ]
    },
    "deploy":                  {
      "dependsOn": [
        "build--intl-server",
        "build--service-worker"
      ],
      "executor":  "@angular/fire:deploy",
      "options":   {
        "browserTarget":        "website:angular--browser:production",
        "cloudRunOptions":      { "minInstances": 1 },
        "firebaseHostingSite":  "gavinsawyer-44c46",
        "firebaseProject":      "gavinsawyer-44c46",
        "functionName":         "ssr-website",
        "functionsNodeVersion": "22.22",
        "outputPath":           "dist/apps/website/run",
        "region":               "us-central1",
        "serverTarget":         "website:angular--server:production",
        "ssr":                  "cloud-run",
        "target":               "website"
      }
    },
    "esbuild--intl-server":    {
      "dependsOn": [
        "lint",
        "prebuild"
      ],
      "executor":  "@nx/esbuild:esbuild",
      "options":   {
        "deleteOutputPath": false,
        "esbuildOptions":   {
          "banner": {
            "css": "/*!\n / Copyright © 2026 Gavin William Sawyer. All rights reserved.\n /\n",
            "js":  "/*\n * Copyright © 2026 Gavin William Sawyer. All rights reserved.\n */\n"
          }
        },
        "format":           [ "cjs" ],
        "main":             "apps/website/src/app/main.intl-server.ts",
        "metafile":         true,
        "minify":           true,
        "outputPath":       "dist/apps/website/server",
        "thirdParty":       true,
        "tsConfig":         "apps/website/tsconfig.app.json"
      },
      "outputs":   [ "{workspaceRoot}/dist/apps/website/server" ]
    },
    "lint":                    {
      "executor": "@nx/eslint:lint",
      "inputs":   [
        "{workspaceRoot}/apps/website/src/.gitInfoPartial.ts",
        "{workspaceRoot}/apps/website/src/.packageRepositoryUrl.ts",
        "{workspaceRoot}/apps/website/src/.packageVersion.ts"
      ],
      "options":  {
        "lintFilePatterns": [
          "apps/website/src/**/*.ts",
          "apps/website/src/**/*.html"
        ]
      }
    },
    "prebuild":                {
      "executor": "nx:run-commands",
      "options":  {
        "commands": [
          "rm -rf dist/apps/website",
          "node -p \"'import { type GitInfo } from \\'git-describe\\';\\n\\n\\nexport const gitInfoPartial: Partial<GitInfo> = ' + JSON.stringify(((gitInfo) => ({dirty: gitInfo.dirty,hash: gitInfo.hash}))(require('git-describe').gitDescribeSync())) + ';'\" > apps/website/src/.gitInfoPartial.ts",
          "node -p \"'export const packageRepositoryUrl: string = \\\"' + require('./package.json').repository.replace('github:', 'https://github.com/') + '\\\" as const;'\" > apps/website/src/.packageRepositoryUrl.ts",
          "node -p \"'export const packageVersion: string = \\\"' + require('./package.json').version + '\\\" as const;'\" > apps/website/src/.packageVersion.ts"
        ]
      },
      "outputs":  [
        "{workspaceRoot}/apps/website/src/.gitInfoPartial.ts",
        "{workspaceRoot}/apps/website/src/.packageRepositoryUrl.ts",
        "{workspaceRoot}/apps/website/src/.packageVersion.ts"
      ]
    }
  }
}
